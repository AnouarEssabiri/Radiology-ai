{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "**/*.py",
      "**/*.yaml",
      "**/*.txt",
      "**/*.html",
      ".gitattributes",
      ".gitignore",
      "datasets/processed/vocab.pkl",
      "datasets/processed/annotations.json",
      "ai_model/checkpoints/*.pth",
      "Dockerfile"
    ]
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
